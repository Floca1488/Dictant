<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>Диктант</title>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body {
  background: #0d0d0d;
  color: #fff;
  font-family: 'Courier New', monospace;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24px;
}
h1 { font-size: 13px; letter-spacing: 5px; text-transform: uppercase; color: #444; margin-bottom: 50px; }
.btn {
  width: 110px; height: 110px; border-radius: 50%;
  border: 2px solid #333; background: #111;
  cursor: pointer; display: flex; align-items: center;
  justify-content: center; font-size: 38px; transition: all 0.25s;
  position: relative; -webkit-tap-highlight-color: transparent; user-select: none;
}
.btn.active { border-color: #7c3aed; background: #1a0a30; box-shadow: 0 0 30px #7c3aed55; }
.btn.active::after {
  content: ''; position: absolute; inset: -10px; border-radius: 50%;
  border: 1px solid #7c3aed66; animation: ripple 1.4s ease-out infinite;
}
@keyframes ripple { 0% { transform: scale(1); opacity: 0.7; } 100% { transform: scale(1.6); opacity: 0; } }
#status { margin-top: 36px; font-size: 12px; letter-spacing: 3px; color: #444; text-transform: uppercase; min-height: 18px; transition: color 0.3s; }
#status.on { color: #a78bfa; } #status.say { color: #34d399; } #status.err { color: #f87171; }
#word-display { margin-top: 48px; font-size: 32px; letter-spacing: 8px; color: #fff; min-height: 44px; text-transform: uppercase; }
#letters-display { margin-top: 14px; font-size: 13px; letter-spacing: 5px; color: #555; min-height: 20px; }
.hint { position: fixed; bottom: 24px; font-size: 11px; color: #2a2a2a; letter-spacing: 1px; text-align: center; padding: 0 20px; }
</style>
</head>
<body>
<h1>Диктант</h1>
<div class="btn" id="micBtn" onclick="toggle()">🎙️</div>
<div id="status">нажми чтобы начать</div>
<div id="word-display"></div>
<div id="letters-display"></div>
<div class="hint">слышит учителя → говорит тебе по буквам в наушник</div>
<script>
let recognition=null,running=false,speaking=false,queue=[];
const btn=document.getElementById('micBtn');
const status=document.getElementById('status');
const wordDisplay=document.getElementById('word-display');
const lettersDisplay=document.getElementById('letters-display');
const synth=window.speechSynthesis;
function setStatus(t,c){status.textContent=t;status.className=c||'';}
function toggle(){if(!running)start();else stop();}
function start(){
  const SR=window.SpeechRecognition||window.webkitSpeechRecognition;
  if(!SR){setStatus('не поддерживается','err');return;}
  recognition=new SR();
  recognition.lang='ru-RU';
  recognition.continuous=true;
  recognition.interimResults=true;
  recognition.onstart=()=>{running=true;btn.classList.add('active');setStatus('слушаю...','on');};
  recognition.onresult=(e)=>{
    for(let i=e.resultIndex;i<e.results.length;i++){
      if(e.results[i].isFinal){
        const text=e.results[i][0].transcript.trim().toLowerCase();
        const words=text.split(/\s+/).filter(w=>w.length>0);
        words.forEach(w=>{const clean=w.replace(/[^а-яёa-z]/gi,'');if(clean.length>0)queue.push(clean);});
        processQueue();
      }
    }
  };
  recognition.onerror=(e)=>{if(e.error!=='no-speech')setStatus('ошибка: '+e.error,'err');};
  recognition.onend=()=>{if(running)recognition.start();};
  recognition.start();
}
function stop(){running=false;if(recognition)recognition.stop();btn.classList.remove('active');setStatus('остановлено');synth.cancel();queue=[];speaking=false;}
function processQueue(){if(speaking||queue.length===0)return;const word=queue.shift();speakWord(word);}
function speakWord(word){
  speaking=true;
  const letters=word.split('');
  wordDisplay.textContent=word.toUpperCase();
  lettersDisplay.textContent=letters.join(' · ');
  setStatus('диктую по буквам...','say');
  speakLetters(letters,0,()=>{speaking=false;setStatus('слушаю...','on');setTimeout(processQueue,500);});
}
function speakLetters(letters,i,done){
  if(i>=letters.length){done();return;}
  const u=new SpeechSynthesisUtterance(letters[i]);
  u.lang='ru-RU';u.rate=0.8;u.pitch=1.0;u.volume=1.0;
  u.onend=()=>setTimeout(()=>speakLetters(letters,i+1,done),200);
  u.onerror=()=>speakLetters(letters,i+1,done);
  synth.speak(u);
}
document.addEventListener('touchstart',()=>{const u=new SpeechSynthesisUtterance('');synth.speak(u);},{once:true});
</script>
</body>
</html>
